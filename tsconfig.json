{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        /* Path aliases - shadcn compatible */
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./assets/src/*"
            ],
            "@app/*": [
                "./assets/src/*"
            ],
            "@utils/*": [
                "./assets/src/utils/*"
            ],
            "@styles/*": [
                "./assets/src/styles/*"
            ],
            "@core/*": [
                "./assets/src/core/*"
            ],
            "@admin/*": [
                "./assets/src/admin/*"
            ],
            "@core-ui/*": [
                "./assets/src/core-ui/*"
            ]
        }
    },
    "include": [
        "assets/src"
    ],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}